function bWM(l){var price=(parseInt(l.price)||0).toLocaleString("ar-SA"),feats=(l.features||[]).join(" - "),map=(l.lat&&l.lng)?"\nالموقع: https://maps.google.com/?q="+l.lat+","+l.lng:"";var m=CFG.name+"\n---\n"+l.title+"\nالمرجع: "+(l.ref||"-")+"\n\nالموقع: "+l.city+" - "+l.area+"\nالنوع: "+(TN[l.type]||"")+(l.deal==="sale"?" - للبيع":" - للإيجار")+"\nالسعر: "+price+" ريال\n";if(l.space)m+="المساحة: "+l.space+" م2\n";if(l.rooms)m+="الغرف: "+l.rooms+"  الحمامات: "+(l.baths||"-")+"\n";if(l.floor)m+="الطابق: "+l.floor+"\n";if(l.year)m+="سنة البناء: "+l.year+"\n";if(feats)m+="\nالمميزات:\n"+feats+"\n";if(l.desc)m+="\n"+l.desc+"\n";m+="\n---\nللتواصل: "+(l.phone||CFG.wa)+map+"\n"+CFG.broker;return m;}
function oWA(lid,ph){var l=null;for(var i=0;i<DB.listings.length;i++){if(DB.listings[i].id===lid){l=DB.listings[i];break;}}if(!l)return;g("wa-ph").value=ph||"";g("wa-msg").value=bWM(l);od("drw-wa");}
function sendWa(){var ph=g("wa-ph").value.trim(),msg=g("wa-msg").value;if(!ph){toast("أدخل رقم المستلم");return;}window.open("https://wa.me/"+fPh(ph)+"?text="+encodeURIComponent(msg),"_blank");cd("drw-wa");}
function oSL(){var url=CFG.url||(window.location.protocol+"//"+window.location.host+"/");g("sl-ph").value="";g("sl-msg").value=CFG.welcome.replace("{broker}",CFG.broker).replace("{company}",CFG.name).replace("{url}",url);od("drw-sl");}
function sendLink(){var ph=g("sl-ph").value.trim(),msg=g("sl-msg").value;if(!ph){toast("أدخل رقم العميل");return;}window.open("https://wa.me/"+fPh(ph)+"?text="+encodeURIComponent(msg),"_blank");cd("drw-sl");}

/* ── ANALYTICS ── */
function bA(){
  var av=0,ac=0;for(var i=0;i<DB.listings.length;i++){if(DB.listings[i].status==="available")av++;}for(var j=0;j<DB.subs.length;j++){if(DB.subs[j].status==="accepted")ac++;}
  var tC={villa:"#C9A84C",apartment:"#3B82F6",land:"#22C55E",commercial:"#F97316"},types=["villa","apartment","land","commercial"],b1="";
  for(var t=0;t<types.length;t++){var tp=types[t],cnt=DB.listings.filter(function(l){return l.type===tp;}).length,pct=DB.listings.length?Math.round((cnt/DB.listings.length)*100):0;b1+='<div class="ab-w"><div class="ab-t"><span>'+esc(TN[tp])+'</span><span style="color:'+tC[tp]+';font-weight:700;">'+cnt+'</span></div><div class="ab"><div class="ab-f" style="width:'+pct+'%;background:'+tC[tp]+';"></div></div></div>';}
  var sK=["new","contacted","accepted","rejected"],b2="";
  for(var sk=0;sk<sK.length;sk++){var key=sK[sk],ssi=SS[key],n=DB.subs.filter(function(s){return s.status===key;}).length,p2=DB.subs.length?Math.round((n/DB.subs.length)*100):0;b2+='<div class="ab-w"><div class="ab-t"><span>'+esc(ssi.ar)+'</span><span style="color:'+ssi.c+';font-weight:700;">'+n+'</span></div><div class="ab"><div class="ab-f" style="width:'+p2+'%;background:'+ssi.c+';opacity:.75;"></div></div></div>';}
  return '<div class="stats">'+sc("العقارات",DB.listings.length,"إجمالي","cg")+sc("المتاح",av,"عقار","cgr")+sc("الواردة",DB.subs.length,"إعلان","cbl")+sc("العملاء",DB.clients.length,"عميل","cg")+'</div>'
    +'<div class="an-c"><div class="an-t">توزيع العقارات</div>'+b1+'</div>'
    +'<div class="an-c"><div class="an-t">حالة الإعلانات الواردة</div>'+b2+'</div>';
}

