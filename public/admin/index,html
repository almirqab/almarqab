<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
<title>المرقاب الذهبي — لوحة التحكم</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
:root {
  --g:  #C9A84C;  --g2: #E8C97A;
  --bg: #0A0A0A;  --c1: #111111;  --c2: #181818;  --c3: #202020;
  --tx: #F0EAE0;  --mu: #666;     --mu2:#999;
  --br: #222;     --br2:#2A2A2A;
  --gr: #22C55E;  --rd: #EF4444;  --bl: #3B82F6;  --yw: #EAB308;
}
body { font-family:'Tajawal',sans-serif; background:var(--bg); color:var(--tx); }
input,select,textarea,button { font-family:'Tajawal',sans-serif; -webkit-appearance:none; outline:none; }
button { cursor:pointer; }
::-webkit-scrollbar { width:3px; } ::-webkit-scrollbar-thumb { background:var(--c3); border-radius:3px; }

/* ─── LOGIN ─── */
#pg-login {
  min-height:100vh; display:flex; align-items:center;
  justify-content:center; padding:20px;
  background: radial-gradient(ellipse at 50% 0%, rgba(201,168,76,.08) 0%, transparent 55%);
}
.lb { width:100%; max-width:360px; }
.lb-brand { text-align:center; margin-bottom:30px; }
.lb-ico {
  width:72px; height:72px; border-radius:20px;
  background:linear-gradient(135deg,var(--g),var(--g2));
  display:flex; align-items:center; justify-content:center;
  font-size:28px; font-weight:900; color:var(--bg);
  margin:0 auto 14px; box-shadow:0 10px 32px rgba(201,168,76,.3);
}
.lb-name { font-size:22px; font-weight:900; }
.lb-sub  { font-size:13px; color:var(--mu); margin-top:4px; }
.lb-card { background:var(--c1); border:1px solid var(--br2); border-radius:20px; padding:28px 22px; }
.lb-h    { font-size:15px; font-weight:900; text-align:center; margin-bottom:22px; color:var(--mu2); }
.lb-err  {
  background:rgba(239,68,68,.09); border:1px solid rgba(239,68,68,.2);
  border-radius:9px; padding:10px; font-size:13px; color:#FCA5A5;
  text-align:center; margin-bottom:16px; display:none;
}
.lbl { font-size:10px; font-weight:700; color:var(--mu); text-transform:uppercase; letter-spacing:.8px; margin-bottom:6px; }
.linp {
  width:100%; background:var(--c2); border:1.5px solid var(--br2);
  border-radius:10px; padding:12px 14px; color:var(--tx);
  font-size:15px; direction:ltr; margin-bottom:13px; transition:border .2s;
}
.linp:focus { border-color:var(--g); }
.lb-btn {
  width:100%; background:linear-gradient(135deg,var(--g),var(--g2));
  color:var(--bg); border:none; border-radius:11px; padding:14px;
  font-size:16px; font-weight:900; margin-top:6px;
  box-shadow:0 5px 20px rgba(201,168,76,.3);
}
.lb-note { text-align:center; font-size:12px; color:var(--mu); margin-top:14px; }

/* ─── TOPBAR ─── */
#pg-dash { display:none; }
.topbar {
  background:var(--c1); border-bottom:1px solid var(--br);
  height:56px; padding:0 16px; display:flex;
  align-items:center; justify-content:space-between;
  position:sticky; top:0; z-index:50;
}
.tb-l { display:flex; align-items:center; gap:10px; }
.tb-menu {
  width:34px; height:34px; background:var(--c2); border:none;
  border-radius:8px; color:var(--mu); font-size:19px;
  display:none; align-items:center; justify-content:center;
}
.tb-logo {
  width:34px; height:34px; border-radius:10px;
  background:linear-gradient(135deg,var(--g),var(--g2));
  display:flex; align-items:center; justify-content:center;
  font-size:15px; font-weight:900; color:var(--bg);
  box-shadow:0 3px 10px rgba(201,168,76,.25);
}
.tb-name { font-size:14px; font-weight:900; color:var(--g); }
.tb-user { font-size:10px; color:var(--mu); }
.tb-r { display:flex; align-items:center; gap:8px; }
.live {
  display:flex; align-items:center; gap:4px;
  background:rgba(34,197,94,.07); border:1px solid rgba(34,197,94,.18);
  border-radius:20px; padding:4px 10px;
}
.live-dot { width:5px; height:5px; border-radius:50%; background:var(--gr); animation:pu 2s infinite; }
.live-t   { font-size:10px; color:var(--gr); font-weight:700; }
@keyframes pu { 0%,100%{opacity:1} 50%{opacity:.3} }
.tbtn {
  background:var(--c2); border:1px solid var(--br2);
  border-radius:8px; padding:7px 13px; color:var(--mu);
  font-size:12px; font-weight:700;
}
.tbtn.red { color:#FCA5A5; background:rgba(239,68,68,.08); border-color:rgba(239,68,68,.15); }
.dsk { display:flex; }

/* ─── LAYOUT ─── */
.layout { display:block; }
.sidebar {
  width:214px; background:var(--c1); border-left:1px solid var(--br);
  min-height:calc(100vh - 56px); float:left; padding:10px 0;
}
.main-ct { margin-left:214px; min-height:calc(100vh - 56px); }

/* ─── NAV ─── */
.ni {
  display:flex; align-items:center; justify-content:space-between;
  padding:13px 20px; color:var(--mu); font-weight:700; font-size:14px;
  border-right:3px solid transparent; cursor:pointer; transition:all .15s;
}
.ni:hover { color:var(--tx); background:rgba(255,255,255,.03); }
.ni.on    { color:var(--g); background:rgba(201,168,76,.07); border-right-color:var(--g); }
.ni.red   { color:#FCA5A5; }
.ni-badge { background:var(--rd); color:#fff; border-radius:12px; padding:2px 8px; font-size:11px; font-weight:900; }
.ni-sep   { height:1px; background:var(--br); margin:8px 12px; }

/* ─── PAGES ─── */
.pg { padding:20px; max-width:960px; margin:0 auto; }

/* ─── BOT NAV ─── */
.bot-nav { display:none; background:var(--c1); border-top:1px solid var(--br); position:sticky; bottom:0; z-index:40; }
.bn-grid { display:grid; }
.bn-btn  {
  background:transparent; border:none; padding:11px 0 8px;
  display:flex; flex-direction:column; align-items:center;
  gap:3px; position:relative; cursor:pointer;
}
.bn-bar { position:absolute; top:0; left:50%; transform:translateX(-50%); width:30px; height:2px; background:linear-gradient(90deg,var(--g),var(--g2)); border-radius:2px; opacity:0; }
.bn-btn.on .bn-bar { opacity:1; }
.bn-lbl { font-size:11px; font-weight:700; color:var(--mu); }
.bn-btn.on .bn-lbl { color:var(--g); }
.bn-badge {
  position:absolute; top:7px; right:13%;
  background:var(--rd); color:#fff; font-size:8px; font-weight:900;
  width:15px; height:15px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  border:2px solid var(--c1);
}

/* ─── MOB SIDE ─── */
.mob-ov   { display:none; position:fixed; inset:0; background:rgba(0,0,0,.8); z-index:90; }
.mob-side {
  position:fixed; top:56px; right:0; bottom:0;
  width:230px; background:var(--c1); border-left:1px solid var(--br);
  z-index:91; padding:10px 0; transform:translateX(110%); transition:transform .28s ease;
}

/* ─── STAT ROW ─── */
.stats { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-bottom:20px; }
.sc {
  background:var(--c1); border:1px solid var(--br2);
  border-radius:14px; padding:16px 14px;
}
.sc-top { font-size:10px; font-weight:700; color:var(--mu); text-transform:uppercase; letter-spacing:.6px; margin-bottom:10px; }
.sc-num { font-size:28px; font-weight:900; letter-spacing:-1.5px; line-height:1; }
.sc-lbl { font-size:11px; color:var(--mu); margin-top:5px; }
.cg  { color:var(--g);  } .cgr { color:var(--gr); }
.cbl { color:var(--bl); } .crd { color:var(--rd); } .cyw { color:var(--yw); }

/* ─── PILLS ─── */
.pills { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:14px; }
.pill {
  background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.07);
  border-radius:20px; padding:6px 14px; font-size:12px; font-weight:700;
  color:var(--mu); cursor:pointer; transition:all .15s;
}
.pill.on { background:rgba(201,168,76,.1); border-color:rgba(201,168,76,.3); color:var(--g); }
.pill-g  { background:rgba(201,168,76,.07); border-color:rgba(201,168,76,.2); color:var(--g); }

/* ─── SEARCH ─── */
.srch {
  width:100%; background:var(--c1); border:1px solid var(--br2);
  border-radius:10px; padding:11px 16px; color:var(--tx);
  font-size:14px; direction:rtl; margin-bottom:14px; transition:border .2s;
}
.srch:focus { border-color:var(--g); }
.srch::placeholder { color:#444; }

/* ─── SEND LINK ─── */
.sl-btn {
  width:100%; background:linear-gradient(135deg,#075E54,#25D366);
  color:#fff; border:none; border-radius:12px; padding:14px;
  font-size:14px; font-weight:900; margin-bottom:18px; display:block;
  box-shadow:0 4px 18px rgba(37,211,102,.18); letter-spacing:.2px;
}

/* ─── CARDS ─── */
.cards { display:grid; grid-template-columns:repeat(auto-fill,minmax(265px,1fr)); gap:12px; }

/* ─── LISTING CARD ─── */
.lc { background:var(--c1); border:1px solid var(--br2); border-radius:14px; overflow:hidden; cursor:pointer; transition:border-color .15s; }
.lc:active { opacity:.9; }
.lc-img   { width:100%; height:130px; object-fit:cover; display:block; }
.lc-noimg { height:68px; background:var(--c2); display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:700; color:var(--mu); }
.lc-body  { padding:13px 14px; }
.lc-r1    { display:flex; justify-content:space-between; align-items:flex-start; gap:6px; margin-bottom:5px; }
.lc-ttl   { font-weight:800; font-size:13px; line-height:1.35; flex:1; }
.lc-meta  { font-size:11px; color:var(--mu); margin-bottom:9px; }
.lc-r2    { display:flex; justify-content:space-between; align-items:center; margin-bottom:11px; }
.lc-price { font-size:15px; font-weight:900; color:var(--g); }
.lc-info  { font-size:11px; color:var(--mu); }
.btn-wa   { width:100%; background:linear-gradient(135deg,#075E54,#25D366); color:#fff; border:none; border-radius:9px; padding:10px; font-size:13px; font-weight:900; }

/* ─── BADGE ─── */
.bdg { display:inline-block; padding:3px 9px; border-radius:20px; font-size:10px; font-weight:700; white-space:nowrap; flex-shrink:0; }

/* ─── SUB CARD ─── */
.xc { background:var(--c1); border:1px solid var(--br2); border-radius:14px; padding:14px 15px; cursor:pointer; }
.xc-r1    { display:flex; justify-content:space-between; gap:6px; margin-bottom:6px; }
.xc-ttl   { font-weight:800; font-size:13px; flex:1; line-height:1.3; }
.xc-meta  { font-size:11px; color:var(--mu); margin-bottom:8px; }
.xc-r2    { display:flex; justify-content:space-between; align-items:center; margin-bottom:11px; }
.xc-price { font-size:14px; font-weight:900; color:var(--g); }
.xc-own   { font-size:12px; color:var(--mu); display:flex; align-items:center; gap:5px; }
.s-av     { width:22px; height:22px; border-radius:50%; background:rgba(201,168,76,.12); color:var(--g); font-size:11px; font-weight:900; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.xc-acts  { display:grid; grid-template-columns:1fr 1fr; gap:7px; }
.btn-ok   { background:linear-gradient(135deg,#166534,#22c55e); color:#fff; border:none; border-radius:8px; padding:9px; font-size:12px; font-weight:900; }
.btn-no   { background:rgba(239,68,68,.1); color:#FCA5A5; border:1px solid rgba(239,68,68,.2); border-radius:8px; padding:9px; font-size:12px; font-weight:900; }

/* ─── CLIENT CARD ─── */
.cc     { background:var(--c1); border:1px solid var(--br2); border-radius:14px; padding:15px; }
.cc-r1  { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px; }
.c-av   { width:40px; height:40px; border-radius:50%; background:rgba(201,168,76,.1); border:1px solid rgba(201,168,76,.18); display:flex; align-items:center; justify-content:center; font-weight:900; font-size:15px; color:var(--g); flex-shrink:0; }
.c-name { font-size:15px; font-weight:800; margin-bottom:2px; }
.c-meta { font-size:11px; color:var(--mu); }
.c-bgt  { font-size:13px; color:var(--g); font-weight:800; margin:6px 0 8px; }
.c-note { font-size:12px; color:var(--mu); font-style:italic; line-height:1.6; margin-bottom:10px; }
.c-btns { display:grid; grid-template-columns:1fr 1fr 1fr; gap:7px; }
.c-btn  { border:none; border-radius:9px; padding:9px; font-size:12px; font-weight:700; text-decoration:none; display:flex; align-items:center; justify-content:center; cursor:pointer; }

/* ─── DRAWER ─── */
.drw-ov { display:none; position:fixed; inset:0; background:rgba(0,0,0,.9); z-index:200; align-items:flex-end; justify-content:center; }
.drw-ov.open { display:flex; }
.drw { background:var(--c1); border-radius:24px 24px 0 0; border:1px solid var(--br2); border-bottom:none; width:100%; max-width:560px; max-height:91vh; display:flex; flex-direction:column; }
.drw-hd { padding:18px 20px 14px; border-bottom:1px solid var(--br); display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
.drw-ttl { font-weight:900; font-size:15px; color:var(--g); }
.drw-x { width:30px; height:30px; border-radius:8px; background:var(--c2); border:none; color:var(--mu); font-size:15px; }
.drw-body { overflow-y:auto; flex:1; -webkit-overflow-scrolling:touch; }
.drw-foot { padding:14px 20px; border-top:1px solid var(--br); flex-shrink:0; }

/* ─── WA MODAL ─── */
.wa-hd { background:linear-gradient(135deg,#075E54,#128C7E); padding:18px 20px; border-radius:24px 24px 0 0; }
.wa-ttl { color:#fff; font-size:15px; font-weight:900; }
.wa-sub { color:rgba(255,255,255,.6); font-size:11px; margin-top:3px; }

/* ─── FORM ─── */
.df     { padding:16px 20px 22px; }
.df-l   { font-size:10px; font-weight:700; color:var(--mu); text-transform:uppercase; letter-spacing:.8px; margin-bottom:6px; }
.df-i   { width:100%; background:var(--c2); border:1px solid var(--br2); border-radius:9px; padding:11px 13px; color:var(--tx); font-size:14px; margin-bottom:12px; direction:rtl; transition:border .2s; }
.df-i:focus { border-color:var(--g); }
.df-i::placeholder { color:#444; }
.df-i.ltr { direction:ltr; }
.df-row  { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.df-save { width:100%; background:linear-gradient(135deg,var(--g),var(--g2)); color:var(--bg); border:none; border-radius:10px; padding:13px; font-size:15px; font-weight:900; margin-top:8px; box-shadow:0 4px 14px rgba(201,168,76,.25); }
.df-cc   { background:rgba(255,255,255,.06); border:1px solid var(--br2); border-radius:10px; padding:13px 16px; font-size:13px; font-weight:700; color:var(--mu); }

/* ─── DETAIL ─── */
.d-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:13px; }
.d-box  { background:var(--c2); border-radius:9px; padding:10px 12px; }
.d-lbl  { font-size:9px; color:var(--mu); font-weight:700; text-transform:uppercase; letter-spacing:.7px; margin-bottom:3px; }
.d-val  { font-size:13px; font-weight:800; }
.d-own  { background:rgba(201,168,76,.05); border:1px solid rgba(201,168,76,.12); border-radius:12px; padding:14px 15px; margin-bottom:13px; }
.d-oname { font-size:15px; font-weight:800; margin-bottom:3px; }
.d-oph   { font-size:13px; color:var(--mu); direction:ltr; text-align:right; margin-bottom:11px; }
.d-obtns { display:grid; grid-template-columns:1fr 1fr 1fr; gap:7px; }
.d-obtn  { border:none; border-radius:8px; padding:9px; font-size:11px; font-weight:700; text-decoration:none; display:flex; align-items:center; justify-content:center; cursor:pointer; }
.ftags   { display:flex; flex-wrap:wrap; gap:6px; margin-bottom:13px; }
.ftag    { border-radius:6px; padding:4px 10px; font-size:11px; font-weight:700; background:rgba(201,168,76,.07); border:1px solid rgba(201,168,76,.15); color:var(--g); }
.ph-row  { display:flex; gap:7px; margin-bottom:13px; }
.ph-val  { flex:1; background:var(--c2); border-radius:9px; padding:10px 13px; font-size:14px; font-weight:700; direction:ltr; text-align:right; }
.ph-call { background:rgba(59,130,246,.1); border:1px solid rgba(59,130,246,.2); border-radius:9px; padding:10px 13px; color:#60A5FA; font-size:14px; font-weight:700; text-decoration:none; display:flex; align-items:center; }
.ph-cp   { background:var(--c2); border:none; border-radius:9px; padding:10px 13px; color:var(--mu); font-size:13px; cursor:pointer; }
.map-btn { display:flex; align-items:center; gap:8px; background:rgba(59,130,246,.07); border:1px solid rgba(59,130,246,.15); border-radius:9px; padding:9px 14px; color:#60A5FA; font-size:13px; font-weight:700; text-decoration:none; margin-bottom:13px; }
.st-btns { display:grid; grid-template-columns:repeat(4,1fr); gap:6px; margin-bottom:10px; }
.st-btn  { border:none; border-radius:7px; padding:8px 3px; font-size:10px; font-weight:700; cursor:pointer; }

/* ─── ANALYTICS ─── */
.an-c  { background:var(--c1); border:1px solid var(--br2); border-radius:14px; padding:17px; margin-bottom:13px; }
.an-t  { font-size:11px; font-weight:700; color:var(--mu); text-transform:uppercase; letter-spacing:.5px; margin-bottom:15px; }
.ab-w  { margin-bottom:13px; }
.ab-t  { display:flex; justify-content:space-between; margin-bottom:6px; font-size:12px; color:var(--mu); }
.ab    { height:6px; background:rgba(255,255,255,.05); border-radius:3px; }
.ab-f  { height:100%; border-radius:3px; }

/* ─── SETTINGS ─── */
.ss    { background:var(--c1); border:1px solid var(--br2); border-radius:14px; padding:17px; margin-bottom:13px; }
.ss-t  { font-size:13px; font-weight:900; color:var(--g); margin-bottom:14px; }
.ico-g { display:flex; flex-wrap:wrap; gap:7px; margin-bottom:14px; }
.ico-b { width:40px; height:40px; border-radius:9px; border:2px solid var(--br2); background:var(--c2); display:flex; align-items:center; justify-content:center; font-size:18px; cursor:pointer; }
.ico-b.on { border-color:var(--g); background:rgba(201,168,76,.1); }
.col-g { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:14px; }
.col-d { width:30px; height:30px; border-radius:50%; cursor:pointer; border:3px solid transparent; }
.col-d.on { border-color:#fff; box-shadow:0 0 0 2px var(--g); }

/* ─── FEAT PICKER ─── */
.fp-w { display:flex; flex-wrap:wrap; gap:7px; margin-bottom:14px; }
.fp   { padding:6px 12px; border-radius:7px; border:1.5px solid var(--br2); background:transparent; color:var(--mu); font-size:12px; font-weight:700; cursor:pointer; }
.fp.on { border-color:var(--g); background:rgba(201,168,76,.08); color:var(--g); }

/* ─── WA MSG BOX ─── */
.wa-box { background:#0D1A12; border:1px solid rgba(37,211,102,.15); border-radius:10px; padding:11px; }
.wa-ta  { background:transparent; border:none; color:#7A9A7A; font-size:12px; line-height:1.85; resize:none; direction:rtl; width:100%; }
.wa-send { width:100%; background:linear-gradient(135deg,#25D366,#128C7E); color:#fff; border:none; border-radius:10px; padding:13px; font-size:15px; font-weight:900; margin-top:14px; box-shadow:0 4px 14px rgba(37,211,102,.2); }

/* ─── EMPTY ─── */
.empty { text-align:center; padding:60px 20px; color:var(--mu); }
.empty-i { font-size:2.8rem; opacity:.2; margin-bottom:12px; }
.empty-t { font-weight:700; font-size:14px; }

/* ─── TOAST ─── */
#tc { position:fixed; bottom:80px; left:50%; transform:translateX(-50%); z-index:999; pointer-events:none; }

/* ─── RESPONSIVE ─── */
@media(max-width:720px) {
  .sidebar { display:none; 
  .main-ct { margin-left:0; }
}
  .tb-menu { display:flex; }
  .dsk     { display:none !important; }
  .bot-nav { display:block; }
  .stats   { grid-template-columns:1fr 1fr; }
  .cards   { grid-template-columns:1fr; }
  .df-row  { grid-template-columns:1fr; }
  .d-grid  { grid-template-columns:1fr; }
  .pg      { padding:14px; }
}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="pg-login">
  <div class="lb">
    <div class="lb-brand">
      <div class="lb-ico" id="l-ico">م</div>
      <div class="lb-name" id="l-name">المرقاب الذهبي</div>
      <div class="lb-sub">لوحة إدارة الوساطة العقارية</div>
    </div>
