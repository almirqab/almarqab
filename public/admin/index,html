  var grid=g("ls-grid"); if(!grid)return;
  if(!fl.length){grid.innerHTML='<div class="empty" style="grid-column:1/-1"><div class="empty-i">&#127968;</div><div class="empty-t">لا توجد نتائج</div></div>';return;}
  var h="";
