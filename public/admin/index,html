function pI(v,btn){tI=v;document.querySelectorAll(".ico-b").forEach(function(b){b.classList.remove("on");});btn.classList.add("on");}
function pCo(v,btn){tCo=v;document.querySelectorAll(".col-d").forEach(function(b){b.classList.remove("on");});btn.classList.add("on");}
function svSt(){CFG.name=g("s-name").value;CFG.broker=g("s-broker").value;CFG.wa=g("s-wa").value;CFG.url=g("s-url").value;CFG.welcome=g("s-wmsg").value;CFG.user=g("s-user").value;CFG.pass=g("s-pass").value;CFG.icon=tI;CFG.color=tCo;updNav();toast("تم حفظ الإعدادات");}

/* ── API ── */
function apiGet(type, cb) {
  var xhr = new XMLHttpRequest();
  xhr.open("GET", "/api/submissions?type=" + type, true);
  xhr.onreadystatechange = function() {
    if (xhr.readyState === 4 && xhr.status === 200) {
      try { var d = JSON.parse(xhr.responseText); if (d.ok) cb(d.data); } catch(e) {}
    }
  };
  xhr.send();
}

function apiPost(type, body, cb) {
  var xhr = new XMLHttpRequest();
  xhr.open("POST", "/api/submissions?type=" + type, true);
  xhr.setRequestHeader("Content-Type", "application/json");
  xhr.onreadystatechange = function() {
    if (xhr.readyState === 4) { try { var d = JSON.parse(xhr.responseText); if (cb) cb(d); } catch(e) {} }
  };
  xhr.send(JSON.stringify(body));
}

function apiPut(type, body, cb) {
  var xhr = new XMLHttpRequest();
  xhr.open("PUT", "/api/submissions?type=" + type, true);
  xhr.setRequestHeader("Content-Type", "application/json");
  xhr.onreadystatechange = function() {
    if (xhr.readyState === 4) { try { var d = JSON.parse(xhr.responseText); if (cb) cb(d); } catch(e) {} }
  };
  xhr.send(JSON.stringify(body));
}

function apiDel(type, id, cb) {
  var xhr = new XMLHttpRequest();
  xhr.open("DELETE", "/api/submissions?type=" + type, true);
  xhr.setRequestHeader("Content-Type", "application/json");
  xhr.onreadystatechange = function() {
    if (xhr.readyState === 4) { try { var d = JSON.parse(xhr.responseText); if (cb) cb(d); } catch(e) {} }
  };
  xhr.send(JSON.stringify({id: id}));
}

function loadAll() {
  apiGet("listings", function(data) {
    if (data && data.length) { DB.listings = data; if (cur === "listings") goPg("listings"); }
  });
  apiGet("clients", function(data) {
    if (data && data.length) { DB.clients = data; if (cur === "clients") goPg("clients"); }
  });
  apiGet("subs", function(data) {
    if (data && data.length) {
      var changed = false;
      for (var i = 0; i < data.length; i++) {
        var item = data[i], ex = false;
        for (var j = 0; j < DB.subs.length; j++) {
          if (String(DB.subs[j].id) === String(item.id)) { ex = true; break; }
        }
        if (!ex) { DB.subs.unshift(item); changed = true; }
      }
      if (changed) { updNav(); if (cur === "submissions") goPg("submissions"); }
    }
  });
}

/* ── INIT ── */
function initDash(){
  CFG.url=window.location.protocol+"//"+window.location.host+"/";
  updNav();
  goPg("listings");
  loadAll();
  setInterval(loadAll,30000);
}
</script>
