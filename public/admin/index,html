  for(var i=0;i<DB.listings.length;i++){var l=DB.listings[i];if(l.status==="available"){av++;vl+=parseInt(l.price)||0;}if(l.status==="pending")pe++;}
  var keys=["all","available","pending","sold","rented"],lbls={all:"الكل",available:"متاح",pending:"تفاوض",sold:"مباع",rented:"مؤجر"},ph="";
  for(var k=0;k<keys.length;k++){ph+='<div class="pill'+(lF===keys[k]?" on":"")+'" onclick="setLF(\''+keys[k]+'\')">'+lbls[keys[k]]+'</div>';}
  ph+='<div class="pill pill-g" onclick="oAL(null)">+ إضافة عقار</div>';
  return '<div class="stats">'+sc("الإجمالي",DB.listings.length,"عقار","cg")+sc("المتاح",av,"للبيع/إيجار","cgr")+sc("التفاوض",pe,"عقار","cyw")+sc("المحفظة",fP(vl),"ريال","cg")+'</div>'
