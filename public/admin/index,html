      +'<div class="lc-r2"><div class="lc-price">'+fP(l.price)+' <span style="font-size:11px;color:var(--mu);font-weight:400;">ريال</span></div>'
      +'<div class="lc-info">'+(l.space?esc(l.space)+"م&sup2; ":"")+(l.rooms?esc(l.rooms)+"غرف":"")+'</div></div>'
      +'<button class="btn-wa" onclick="event.stopPropagation();oWA('+l.id+',\'\')">إرسال تفاصيل العقار للعميل</button>'
      +'</div></div>';
